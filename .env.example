# ==========================================
# AI Passport Studio — Example Environment
# Copy this file to .env and fill in values
# ==========================================

# 1. FastAPI Server Settings
HOST=127.0.0.1
PORT=8000
RELOAD=True

# 2. File Storage Folder Paths
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
PASSPORT_OUTPUT_FOLDER=outputs/passport
PRINTABLE_OUTPUT_FOLDER=outputs/printable

# 3. Printing Layout Configurations
DPI=300
DEFAULT_MARGIN_MM=8.0
DEFAULT_GAP_MM=2.5

# 4. AI Models Configuration
# Supported: u2net_human_seg (176MB, recommended), u2net (176MB),
#            u2netp (4.7MB, ultra-lightweight), birefnet-general (973MB),
#            birefnet-portrait (300MB)
REMBG_MODEL=u2net_human_seg
