# ==========================================
# AI Passport Studio — .gitignore
# ==========================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec

# ----- Logs -----
*.log
pip-log.txt
pip-delete-this-directory.txt

# ----- Environments -----
.env
.env.*
!.env.example
.venv
env/
venv/
ENV/

# ----- IDE / Editors -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.kate-swp

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ----- Project-specific dynamic folders -----
uploads/
outputs/
temp/

# ----- AI Model Weights (large binary files) -----
# Store locally, do NOT commit to git
*.pth
*.pt
*.onnx
*.pkl
*.bin
gfpgan/weights/

# ----- Temporary / scratch files -----
*.tmp
*.bak
test_*.png
test_*.jpg
test_*.jpeg

# ----- Jupyter -----
.ipynb_checkpoints
*.ipynb
